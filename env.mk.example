# Copy this file to env.mk (ignored by git), then edit for the local machine.
# SPIKE_CXX must support C++17; system GCC 4.8.5 is too old.
SPIKE_CXX  := /path/to/cxx17/g++
NC_INSTALL := /path/to/INCISIVE          # Contains svdpi.h and UVM-1.2
# VCS_HOME := /path/to/vcs                # Optional svdpi.h fallback for VCS
# RISCV_PREFIX := riscv32-unknown-elf-    # Optional toolchain command prefix
